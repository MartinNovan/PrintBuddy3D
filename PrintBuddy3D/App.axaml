<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PrintBuddy3D.App"
             xmlns:suki="using:SukiUI"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:common="clr-namespace:PrintBuddy3D.Common"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <common:ViewLocator/>
    </Application.DataTemplates>
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://PrintBuddy3D/Assets/PrintBuddy3D_no_bg.png" ToolTipText="PrintBuddy3D">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open PrintBuddy3D" Click="TrayIcon_Show_Clicked" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit" Click="TrayIcon_Exit_Clicked" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
    <Application.Styles>
        <FluentTheme/> <!--Needed for the dock to render properly-->
        <StyleInclude Source="avares://SukiUI.Dock/Index.axaml" />
        <suki:SukiTheme ThemeColor="Blue"/>
        <material:MaterialIconStyles/>
    </Application.Styles>
</Application>