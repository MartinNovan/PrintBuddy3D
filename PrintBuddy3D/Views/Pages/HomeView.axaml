<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:PrintBuddy3D.ViewModels.Pages"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="viewmodel:HomeViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PrintBuddy3D.Views.Pages.HomeView">
    
    <Grid RowDefinitions="Auto,*" RowSpacing="5" Margin="5">
        
        <suki:GlassCard Grid.Row="0">
            <StackPanel Spacing="8">
                <TextBlock Text="🖨️ Printers Summary" FontWeight="Bold" FontSize="16"/>
                <ItemsControl ItemsSource="{Binding StatusSummary}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <suki:GlassCard Padding="10,20" Margin="5">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Count}" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </suki:GlassCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </suki:GlassCard>

        <suki:GlassCard Grid.Row="1">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="🔔 Notifications" FontWeight="Bold" FontSize="16" TextAlignment="Center" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Foreground="Red" Content="Clear all" Command="{Binding RemoveAllNotificationCommand}"/>
                </Grid>
                <DataGrid ItemsSource="{Binding NotificationMessages}" HeadersVisibility="None" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding}" Width="*"/>
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Classes="Basic Icon"
                                            DataContext="{Binding $parent[UserControl].DataContext}"
                                            Command="{Binding RemoveNotificationCommand, DataType=viewmodel:HomeViewModel}"
                                            CommandParameter="{Binding $parent[DataGridRow].DataContext}">
                                        <avalonia:MaterialIcon Kind="Close" Foreground="Red"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </suki:GlassCard>
    </Grid>
</UserControl>
